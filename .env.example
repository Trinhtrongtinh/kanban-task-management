# ============ CORE APPLICATION ============
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:3001

# ============ DATABASE (MySQL) ============
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=trello_user
DB_PASSWORD=trello_pass
DB_DATABASE=trello_clone
DB_SSL=false

# ============ JWT AUTHENTICATION ============
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# ============ REDIS (Cache & Rate Limiting) ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============ AUTH COOKIES ============
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_CSRF_COOKIE_NAME=csrf_token
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/social-callback
AUTH_FAILURE_REDIRECT_URL=http://localhost:3000/login?error=social_auth_failed

# ============ GOOGLE OAUTH ============
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ============ EMAIL (Mailer/SMTP) ============
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_user_here
MAIL_PASS=your_mailtrap_password_here
MAIL_FROM=noreply@kanban.app
MAIL_FROM_NAME=Kanban App

# ============ STRIPE PAYMENT ============
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...

# ============ RATE LIMITING ============
# Default limits (applied globally)
RATE_LIMIT_DEFAULT_TTL_MS=60000
RATE_LIMIT_DEFAULT_AUTH_LIMIT=600
RATE_LIMIT_DEFAULT_ANON_LIMIT=300
RATE_LIMIT_DEFAULT_BLOCK_MS=30000

# Auth-specific limits
RATE_LIMIT_AUTH_TTL_MS=60000
RATE_LIMIT_AUTH_LIMIT=10000
RATE_LIMIT_AUTH_BLOCK_MS=300000

# Login-specific limits
RATE_LIMIT_LOGIN_TTL_MS=60000
RATE_LIMIT_LOGIN_LIMIT=5
RATE_LIMIT_LOGIN_BLOCK_MS=900000

# Register-specific limits
RATE_LIMIT_REGISTER_TTL_MS=3600000
RATE_LIMIT_REGISTER_LIMIT=3
RATE_LIMIT_REGISTER_BLOCK_MS=86400000

# Forgot password limits
RATE_LIMIT_FORGOT_PASSWORD_TTL_MS=3600000
RATE_LIMIT_FORGOT_PASSWORD_LIMIT=3
RATE_LIMIT_FORGOT_PASSWORD_BLOCK_MS=300000

# Verify reset token limits
RATE_LIMIT_VERIFY_RESET_TOKEN_TTL_MS=60000
RATE_LIMIT_VERIFY_RESET_TOKEN_LIMIT=10
RATE_LIMIT_VERIFY_RESET_TOKEN_BLOCK_MS=60000

# Reset password limits
RATE_LIMIT_RESET_PASSWORD_TTL_MS=300000
RATE_LIMIT_RESET_PASSWORD_LIMIT=3
RATE_LIMIT_RESET_PASSWORD_BLOCK_MS=3600000

# Search rate limits
RATE_LIMIT_SEARCH_TTL_MS=60000
RATE_LIMIT_SEARCH_LIMIT=10000
RATE_LIMIT_SEARCH_BLOCK_MS=60000

# Upload rate limits
RATE_LIMIT_UPLOAD_TTL_MS=60000
RATE_LIMIT_UPLOAD_LIMIT=10000
RATE_LIMIT_UPLOAD_BLOCK_MS=300000

# Write operations rate limits
RATE_LIMIT_WRITE_TTL_MS=60000
RATE_LIMIT_WRITE_LIMIT=10000
RATE_LIMIT_WRITE_BLOCK_MS=60000

# ============ FRONTEND (Next.js) ============
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
